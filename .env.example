# ─── Supabase ───────────────────────────────────────────────────────────────
# Required when DATA_MODE=supabase
# Copy from your Supabase project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Data mode ───────────────────────────────────────────────────────────────
# "supabase" → use Supabase for products + order persistence.
# Any other value (or blank) → in-memory mock store (no credentials needed).
DATA_MODE=

# Strict mode: set to "true" to fail hard when Supabase products are empty or
# unavailable (instead of silently falling back to local JSON).
# Use with DATA_MODE=supabase to verify the teammate dataset is in place.
# Never set to true in mock/local development.
SUPABASE_STRICT=false

# ─── Manus AI ────────────────────────────────────────────────────────────────
# MANUS_MODE=mock (default)     → local Router Agent handles intent (no credentials)
# MANUS_MODE=external           → call teammate Manus endpoint for intent + reply
# Contract: see apps/backend/src/adapters/manusAdapter.ts
MANUS_MODE=mock
MANUS_ENDPOINT=
MANUS_API_KEY=

# ─── Wassist (WhatsApp API) ──────────────────────────────────────────────────
# TODO: Plug in Wassist sandbox credentials when ready
# Teammate integration point: apps/backend/src/adapters/wassistAdapter.stub.ts
WASSIST_API_KEY=
WASSIST_PHONE_NUMBER_ID=
WASSIST_WEBHOOK_SECRET=

# ─── PayPal ──────────────────────────────────────────────────────────────────
# TODO: Plug in PayPal sandbox credentials when ready
# Teammate integration point: apps/backend/src/adapters/paypalAdapter.stub.ts
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SANDBOX=true

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
