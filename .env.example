# ─── Supabase ───────────────────────────────────────────────────────────────
# TODO: Replace with your Supabase project URL and anon/service key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Wassist (WhatsApp API) ──────────────────────────────────────────────────
# TODO: Plug in Wassist sandbox credentials when ready
WASSIST_API_KEY=
WASSIST_PHONE_NUMBER_ID=
WASSIST_WEBHOOK_SECRET=

# ─── PayPal ──────────────────────────────────────────────────────────────────
# TODO: Plug in PayPal sandbox credentials when ready
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SANDBOX=true

# ─── Manus AI ────────────────────────────────────────────────────────────────
# TODO: Plug in Manus API key for AI analysis (leave empty to use mock)
MANUS_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ─── Data mode ───────────────────────────────────────────────────────────────
# Set to "supabase" to use Supabase for products lookup and order persistence.
# Leave blank (or any other value) to use the in-memory mock store.
# Requires SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY to be set.
DATA_MODE=
