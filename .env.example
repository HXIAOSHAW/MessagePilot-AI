# ─── Supabase ───────────────────────────────────────────────────────────────
# TODO: Replace with your Supabase project URL and anon/service key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Wassist (WhatsApp API) ──────────────────────────────────────────────────
# TODO: Plug in Wassist sandbox credentials when ready
WASSIST_API_KEY=
WASSIST_PHONE_NUMBER_ID=
WASSIST_WEBHOOK_SECRET=

# ─── PayPal ──────────────────────────────────────────────────────────────────
# TODO: Plug in PayPal sandbox credentials when ready
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SANDBOX=true

# ─── Manus AI (complaint agent brain) ────────────────────────────────────────
# Powers the complaint agent's reasoning (severity + decision + reply).
# Leave empty to run the deterministic fallback flow (works with the mock store).
# Get a key at https://open.manus.ai (Authentication).
MANUS_API_KEY=
MANUS_BASE_URL=https://api.manus.ai
# Agent profile: manus-1.6 | manus-1.6-lite | manus-1.6-max
MANUS_AGENT_PROFILE=manus-1.6-lite
# Manus tasks are async; how long to poll for the structured result (ms).
MANUS_POLL_TIMEOUT_MS=120000
MANUS_POLL_INTERVAL_MS=3000

# ─── Owner notifications / identity ──────────────────────────────────────────
# WhatsApp number to ping on escalations (optional).
OWNER_WHATSAPP=
# Shop name used in agent prompts and customer replies.
SHOP_NAME=OrderPilot

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ─── Data mode ───────────────────────────────────────────────────────────────
# Set to "supabase" to use Supabase for products lookup and order persistence.
# Leave blank (or any other value) to use the in-memory mock store.
# Requires SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY to be set.
DATA_MODE=
